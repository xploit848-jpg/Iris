<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/iris_bg">

    <com.aetherai.iris.ui.OrbView
        android:id="@+id/orb_view"
        android:layout_width="220dp"
        android:layout_height="220dp" />

    <TextView
        android:id="@+id/status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Idle"
        android:textColor="@color/iris_text_secondary"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/mic_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:padding="16dp"
        android:text="Tap to speak"
        android:textColor="@color/iris_text_primary"
        android:background="@color/iris_surface_alt"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>
